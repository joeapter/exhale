// Exhale — Desert Escape for Women
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────
// AUTHENTICATION
// ─────────────────────────────────────────────────────

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String    // bcrypt hash
  role      AdminRole @default(EDITOR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  paymentLinks PaymentLink[]

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ─────────────────────────────────────────────────────
// RETREATS
// ─────────────────────────────────────────────────────

model Retreat {
  id             String         @id @default(cuid())
  slug           String         @unique
  status         RetreatStatus  @default(DRAFT)

  // Content
  title          String
  tagline        String?
  overview       String         @db.Text
  philosophy     String?        @db.Text
  location       String
  locationDetail String?        @db.Text
  itinerary      Json?
  inclusions     String[]
  exclusions     String[]
  accommodations String?        @db.Text
  dining         String?        @db.Text

  // Dates & Capacity
  startDate      DateTime
  endDate        DateTime
  capacity       Int
  spotsRemaining Int

  // Images
  heroImage      String?
  images         RetreatImage[]

  // Packages
  packages       RetreatPackage[]

  // Relations
  faqs           RetreatFaq[]
  registrations  Registration[]
  rooms          Room[]
  expenses       Expense[]

  // Meta
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("retreats")
}

enum RetreatStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  COMPLETED
  CANCELED
}

model RetreatImage {
  id        String   @id @default(cuid())
  retreatId String
  retreat   Retreat  @relation(fields: [retreatId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("retreat_images")
}

model RetreatPackage {
  id            String         @id @default(cuid())
  retreatId     String
  retreat       Retreat        @relation(fields: [retreatId], references: [id], onDelete: Cascade)
  name          String
  description   String?        @db.Text
  occupancy     String?
  images        String[]
  fullPrice     Int
  depositAmount Int
  capacity      Int            @default(1)
  available     Int
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  registrations Registration[]
  stripeProductId      String?  @unique
  stripeDepositPriceId String?  @unique
  stripeFullPriceId    String?  @unique
  stripeSyncedAt       DateTime?
  stripeSyncError      String?  @db.Text

  @@map("retreat_packages")
}

// ─────────────────────────────────────────────────────
// REGISTRATIONS
// ─────────────────────────────────────────────────────

model Registration {
  id              String             @id @default(cuid())
  retreatId       String
  retreat         Retreat            @relation(fields: [retreatId], references: [id])
  packageId       String?
  package         RetreatPackage?    @relation(fields: [packageId], references: [id])
  status          RegistrationStatus @default(PENDING)

  // Attendee
  firstName       String
  lastName        String
  email           String
  phone           String?
  dateOfBirth     DateTime?

  // Preferences
  dietaryNeeds    String?            @db.Text
  healthNotes     String?            @db.Text
  roomingPref     RoomingPreference  @default(NO_PREFERENCE)
  additionalNotes String?            @db.Text

  // Emergency contact
  emergencyName   String?
  emergencyPhone  String?
  emergencyRel    String?

  // Room assignment
  roomId          String?
  room            Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)

  // Payment
  paymentType     PaymentType        @default(FULL)
  payments        Payment[]
  paymentLinks    PaymentLink[]
  stripeSessionId String?
  stripeCustomerId String?
  amountDue       Int
  amountPaid      Int                @default(0)
  inventoryStatus InventoryStatus    @default(HELD)
  holdExpiresAt   DateTime?
  termsAcceptedAt DateTime?
  termsVersion    String?

  // Staff
  isStaff         Boolean            @default(false)

  // Confirmation
  confirmedAt     DateTime?
  confirmationRef String?            @unique

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("registrations")
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  CANCELED
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  FULL
}

enum InventoryStatus {
  HELD
  CONFIRMED
  RELEASED
}

enum RoomingPreference {
  SOLO
  WITH_FRIEND
  NO_PREFERENCE
}

model Payment {
  id              String        @id @default(cuid())
  registrationId  String
  registration    Registration  @relation(fields: [registrationId], references: [id])
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod @default(STRIPE)
  kind            PaymentKind   @default(BALANCE)
  amount          Int           // ILS credit in agorot
  currency        String        @default("ILS")
  chargedAmount   Int?
  chargedCurrency String?
  exchangeRate    Decimal?      @db.Decimal(18, 9)
  exchangeRateSource String?
  exchangeRateQuotedAt DateTime?
  stripeFxQuoteId String?
  stripePaymentId String?       @unique
  stripeSessionId String?       @unique
  notes           String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
  FAILED
}

enum PaymentMethod {
  STRIPE
  BANK_TRANSFER
  BIT
  CASH
  OTHER
}

enum PaymentKind {
  DEPOSIT
  FULL
  BALANCE
  ADJUSTMENT
}

model PaymentLink {
  id              String            @id @default(cuid())
  token           String            @unique
  registrationId  String
  registration    Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  createdById     String?
  createdBy       AdminUser?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  kind            PaymentKind
  status          PaymentLinkStatus @default(OPEN)
  amount          Int               // ILS credit in agorot
  currency        String            @default("ILS")
  chargedAmount   Int?
  chargedCurrency String?
  exchangeRate    Decimal?          @db.Decimal(18, 9)
  exchangeRateSource String?
  exchangeRateQuotedAt DateTime?
  stripeFxQuoteId String?
  stripeSessionId String?           @unique
  expiresAt       DateTime
  paidAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("payment_links")
}

enum PaymentLinkStatus {
  OPEN
  PAID
  EXPIRED
  CANCELED
}

// ─────────────────────────────────────────────────────
// CONTENT
// ─────────────────────────────────────────────────────

model Facilitator {
  id        String   @id @default(cuid())
  name      String
  title     String?
  image     String?
  bio       String   @db.Text
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("facilitators")
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  location   String?
  quote      String   @db.Text
  retreatRef String?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("testimonials")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model RetreatFaq {
  id        String  @id @default(cuid())
  retreatId String
  retreat   Retreat @relation(fields: [retreatId], references: [id], onDelete: Cascade)
  question  String
  answer    String  @db.Text
  sortOrder Int     @default(0)

  @@map("retreat_faqs")
}

model SiteContent {
  id        String      @id @default(cuid())
  key       String      @unique
  label     String
  value     String      @db.Text
  type      ContentType @default(TEXT)
  updatedAt DateTime    @updatedAt

  @@map("site_content")
}

enum ContentType {
  TEXT
  RICHTEXT
  IMAGE_URL
  JSON
}

// ─────────────────────────────────────────────────────
// ROOM ORGANIZER
// ─────────────────────────────────────────────────────

model Room {
  id            String         @id @default(cuid())
  retreatId     String
  retreat       Retreat        @relation(fields: [retreatId], references: [id], onDelete: Cascade)
  name          String
  capacity      Int
  sortOrder     Int            @default(0)
  registrations Registration[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("rooms")
}

// ─────────────────────────────────────────────────────
// MAILING LIST
// ─────────────────────────────────────────────────────

model MailingListSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  source    String?
  createdAt DateTime @default(now())

  @@map("mailing_list_subscribers")
}

// ─────────────────────────────────────────────────────
// SITE SETTINGS
// ─────────────────────────────────────────────────────

model SiteSettings {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─────────────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────────────

model Expense {
  id          String   @id @default(cuid())
  retreatId   String?
  retreat     Retreat? @relation(fields: [retreatId], references: [id], onDelete: SetNull)
  description String
  amount      Int      // agorot
  category    String?
  date        DateTime @default(now())
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}
